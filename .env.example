# =============================================================================
# CloudDash — Environment Configuration
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# Supported: google | sarvam | groq | nvidia
# Fallback chain: google → sarvam → groq → nvidia
# -----------------------------------------------------------------------------
LLM_PROVIDER=sarvam

# Google Gemini — https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIza...your-key-here

# Sarvam AI — https://platform.sarvam.ai/ (multilingual, Indian languages)
SARVAM_API_KEY=...your-key-here

# Groq — https://console.groq.com/ (fast inference)
GROQ_API_KEY=gsk_...your-key-here

# NVIDIA AI Endpoints — https://build.nvidia.com  (free tier: 40 RPM)
NVIDIA_API_KEY=nvapi-...your-key-here

# Models — fast classifier + stronger specialist pattern
LLM_REASONING_MODEL=sarvam-105b                   # specialists + judge
LLM_FAST_MODEL=sarvam-30b                         # triage, guardrails, rewriter
LLM_JUDGE_MODEL=sarvam-105b                       # eval harness (stricter)
LLM_TEMPERATURE=0.0                                # 0.0 for determinism
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Observability — LangSmith (optional, JD's #1 tool)
# Get a free key at https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_...your-key-here
LANGCHAIN_PROJECT=clouddash-multi-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# Retrieval Configuration (CRAG)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5    # local, ~130MB, no API cost
CHROMA_PERSIST_DIR=./data/chroma
RETRIEVAL_TOP_K_DENSE=10                  # candidates from dense
RETRIEVAL_TOP_K_BM25=10                   # candidates from BM25
RETRIEVAL_TOP_K_FUSED=10                  # after RRF fusion
RETRIEVAL_TOP_K_RERANKED=4                # final passed to LLM
RERANKER_TYPE=cohere                      # cohere | llm | cross_encoder | none
GROUNDING_MIN_SCORE=0.25                  # below = trigger "not in KB" path

# Cohere Rerank API — https://cohere.com/ (required for RERANKER_TYPE=cohere)
COHERE_API_KEY=...your-key-here

# Tavily Web Search — https://tavily.com/ (for CRAG web fallback)
TAVILY_API_KEY=tvly-...your-key-here

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                       # development | production
LOG_LEVEL=INFO
LOG_DIR=./logs
AUDIT_LOG_PATH=./logs/audit.jsonl
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Guardrails
# -----------------------------------------------------------------------------
MAX_INPUT_LENGTH=4000                     # chars per user message
MAX_TURNS_PER_CONVERSATION=20
SELF_CORRECTION_MAX_ATTEMPTS=2

# -----------------------------------------------------------------------------
# Mock CRM (Billing Agent uses this)
# -----------------------------------------------------------------------------
MOCK_CRM_PATH=./data/mock_customers.json

# -----------------------------------------------------------------------------
# Eval Harness
# -----------------------------------------------------------------------------
# Inter-scenario sleep — respects NVIDIA 40 RPM limit (default 6s)
EVAL_SCENARIO_SLEEP_S=6
