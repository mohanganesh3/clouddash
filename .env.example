# =============================================================================
# CloudDash — Environment Configuration
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# Supported: nvidia | groq | google
# -----------------------------------------------------------------------------
LLM_PROVIDER=nvidia

# NVIDIA AI Endpoints — https://build.nvidia.com  (free tier: 40 RPM)
NVIDIA_API_KEY=nvapi-...your-key-here

# Optional alternatives (set the matching key if you change LLM_PROVIDER)
# GROQ_API_KEY=gsk_...your-key-here
# GOOGLE_API_KEY=AIza...your-key-here

# Models — cheap classifier + smart reasoner pattern (Anthropic research-system)
LLM_REASONING_MODEL=meta/llama-3.3-70b-instruct   # specialists + judge
LLM_FAST_MODEL=meta/llama-3.1-8b-instruct         # triage, guardrails, rewriter
LLM_JUDGE_MODEL=meta/llama-3.3-70b-instruct       # eval harness (stricter)
LLM_TEMPERATURE=0.0                                # 0.0 for determinism
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Observability — LangSmith (optional, JD's #1 tool)
# Get a free key at https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_...your-key-here
LANGCHAIN_PROJECT=clouddash-multi-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# Retrieval Configuration
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5    # local, ~130MB, no API cost
CHROMA_PERSIST_DIR=./data/chroma
RETRIEVAL_TOP_K_DENSE=10                  # candidates from dense
RETRIEVAL_TOP_K_BM25=10                   # candidates from BM25
RETRIEVAL_TOP_K_FUSED=10                  # after RRF fusion
RETRIEVAL_TOP_K_RERANKED=4                # final passed to LLM
RERANKER_TYPE=llm                         # llm | cross_encoder | none
GROUNDING_MIN_SCORE=0.25                  # below = trigger "not in KB" path

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                       # development | production
LOG_LEVEL=INFO
LOG_DIR=./logs
AUDIT_LOG_PATH=./logs/audit.jsonl
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Guardrails
# -----------------------------------------------------------------------------
MAX_INPUT_LENGTH=4000                     # chars per user message
MAX_TURNS_PER_CONVERSATION=20
SELF_CORRECTION_MAX_ATTEMPTS=2

# -----------------------------------------------------------------------------
# Mock CRM (Billing Agent uses this)
# -----------------------------------------------------------------------------
MOCK_CRM_PATH=./data/mock_customers.json

# -----------------------------------------------------------------------------
# Eval Harness
# -----------------------------------------------------------------------------
# Inter-scenario sleep — respects NVIDIA 40 RPM limit (default 6s)
EVAL_SCENARIO_SLEEP_S=6
